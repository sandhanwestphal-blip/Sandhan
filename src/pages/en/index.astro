---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Sandhan Westphal – Spiritual Life Counselling | Leipzig"
  description="Over 40 years of lived spiritual practice. Sandhan Westphal accompanies people in Leipzig with NLP, hypnosis, meditation and coaching."
>
  <Nav />
  <main class="coming-soon">
    <div class="coming-soon__inner">
      <p class="eyebrow">English version</p>
      <h1>Coming soon</h1>
      <p class="lead">
        The English version of this website is currently being prepared.
        In the meantime, feel free to get in touch directly.
      </p>
      <a href="mailto:Sandhanwestphal@gmail.com" class="cta">Send an email</a>
      <a href="/" class="back-link">← Deutsche Version</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .coming-soon {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    background: var(--sand);
  }

  .coming-soon__inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--deep);
    margin-bottom: 1.5rem;
  }

  .lead {
    font-size: 1rem;
    color: var(--text-light);
    margin-bottom: 2rem;
    max-width: 440px;
  }

  .cta {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: var(--terracotta);
    color: #fff;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-right: 1.5rem;
    transition: background 0.2s;
  }

  .cta:hover {
    background: var(--deep);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }

  .back-link:hover {
    color: var(--terracotta);
  }
</style>
